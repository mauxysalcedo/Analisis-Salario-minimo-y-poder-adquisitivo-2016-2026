   "source": [
    "df_matriculapublica = pd.read_excel(ruta_costo_matricula_publica)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "54af8e86-41af-4072-9a9f-761706ece8ea",
