   "source": [
    "## Tabla Maestra Final\n",
    "\n",
    "Todos los indicadores calculados en una sola vista."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1235e9d9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Tabla Maestra Final ───────────────────────────────────────────────────────\n",
    "\n",
    "cols_final = [\n",
    "    \"Año\", \"Salario_nominal\", \"Auxilio_transporte\", \"IPC\", \"Mes_IPC\",\n",
    "    \"Salario_real\", \"Linea_pobreza\", \"Ingreso_total\",\n",
    "    \"Excedente\", \"Excedente_semestral\"\n",
    "]\n",
    "\n",
    "# Excluir 2026 — IPC parcial (solo hasta mayo), no comparable con años completos\n",
    "df_final = df_maestro[cols_final].copy()\n",
    "df_final = df_final[df_final[\"Año\"] <= 2025].reset_index(drop=True)\n",
    "\n",
    "# Renombrar columnas\n",
    "display_cols = {\n",
    "    \"Año\":                 \"Año\",\n",
    "    \"Salario_nominal\":     \"Salario nominal\",\n",
    "    \"Auxilio_transporte\":  \"Auxilio transporte\",\n",
    "    \"IPC\":                 \"IPC (último mes)\",\n",
    "    \"Mes_IPC\":             \"Mes IPC\",\n",
    "    \"Salario_real\":        \"Salario real (precios constantes)\",\n",
    "    \"Linea_pobreza\":       \"Línea de pobreza\",\n",
    "    \"Ingreso_total\":       \"Ingreso total\",\n",
    "    \"Excedente\":           \"Excedente mensual\",\n",
    "    \"Excedente_semestral\": \"Excedente semestral\"\n",
    "}\n",
    "df_final_display = df_final.rename(columns=display_cols)\n",
    "\n",
    "# Guardar CSV sin 2026\n",
    "df_final.to_csv(\"datos_poder_adquisitivo/tabla_maestra.csv\", index=False)\n",
    "print(\"Tabla guardada (2016–2025) en datos_poder_adquisitivo/tabla_maestra.csv\")\n",
    "print()\n",
    "print(\"Nota: 2026 se excluye de esta tabla porque el IPC disponible es parcial\")\n",
    "print(\"(dato hasta mayo 2026), lo que no permite una comparación rigurosa\")\n",
    "print(\"con los años anteriores que tienen el año completo cerrado.\")\n",
    "print()\n",
    "\n",
    "df_final_display.style.format({\n",
    "    \"Salario nominal\":                   \"${:,.0f}\",\n",
    "    \"Auxilio transporte\":                \"${:,.0f}\",\n",
    "    \"IPC (último mes)\":                  \"{:.2f}\",\n",
    "    \"Salario real (precios constantes)\": \"${:,.0f}\",\n",
    "    \"Línea de pobreza\":                  \"${:,.0f}\",\n",
    "    \"Ingreso total\":                     \"${:,.0f}\",\n",
    "    \"Excedente mensual\":                 \"${:,.0f}\",\n",
    "    \"Excedente semestral\":               \"${:,.0f}\"\n",
    "})"
   ]
